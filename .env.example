# Copy file này thành .env và điền giá trị. Không commit file .env.

# Bắt buộc: chuỗi bí mật dùng để mã hóa WebSocket (phải trùng với app Android và frontend).
# Nếu đang dùng bản cũ, đặt giống key cũ ví dụ: MonitorTournamentSecretKey2026!
SECRET_KEY=your-secret-key-here

# Tùy chọn: port và host (mặc định 3333, 0.0.0.0)
# PORT=3333
# HOST=0.0.0.0

# Triển khai: LAN (mặc định, bật ADB) | LIVE (giải online, tắt /api/adb)
# DEPLOY_MODE=LAN
# DEPLOY_MODE=LIVE

# Ngưỡng mất kết nối (ms). LIVE nên 12000+; LAN mặc định 5000.
# DISCONNECT_MS=12000

# Tùy chọn: bật login dashboard.
# - Admin PIN: được chỉnh sửa (drag stage, clear logs, upload/push file...)
# - Viewer PIN: chỉ xem
# Tương thích cũ: DASHBOARD_PIN vẫn dùng như Admin PIN nếu chưa tách role.
# DASHBOARD_ADMIN_PIN=1234
# DASHBOARD_VIEWER_PIN=5678
# DASHBOARD_PIN=1234

# Tùy chọn: chu kỳ kiểm tra mạng (ms). Mặc định 5000 (5s). Đặt 1000 để kiểm tra mỗi giây.
# NET_CHECK_INTERVAL_MS=5000

# Tùy chọn: timeout TCP khi probe host:port (ms). Mặc định 5000. Trước đây 300ms dễ báo FAIL với máy chủ Internet xa/chậm.
# NET_TCP_TIMEOUT_MS=5000

# Tùy chọn: Webhook Discord để nhắc vi phạm. Khi có thiết bị vi phạm, bot gửi tin vào kênh (trọng tài theo dõi).
# Tạo webhook: Server Discord → Cài đặt kênh → Tích hợp → Webhook → Tạo. Dán URL vào đây.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Timeout HTTP gửi webhook (ms). Mặc định 20000. Tăng nếu mạng chậm vẫn thấy [Discord] Request timeout.
# DISCORD_WEBHOOK_TIMEOUT_MS=20000

# LIVE: mã giải — app phải nhập đúng mới được gửi heartbeat (tên đội = deviceName trên app).
# TOURNAMENT_CODE=FFWS2026

# LIVE (tùy chọn): SHA-256 pin cert TLS (base64, không prefix sha256/) — app port 443 sẽ pin host.
# Lấy pin: openssl s_client -connect host:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | openssl enc -base64
# CERT_PIN_SHA256=
