# Copy file này thành .env và điền giá trị. Không commit file .env.

# Bắt buộc: chuỗi bí mật dùng để mã hóa WebSocket (phải trùng với app Android và frontend).
SECRET_KEY=MonitorTournamentSecretKey2026!

# Tùy chọn: port và host (mặc định 3000, 0.0.0.0)
# PORT=3000
# HOST=0.0.0.0

# Tùy chọn: nếu đặt PIN, dashboard và API ADB yêu cầu đăng nhập trước.
# DASHBOARD_PIN=1234

# Tùy chọn: chu kỳ kiểm tra mạng (ms). Mặc định 5000 (5s). Đặt 1000 để kiểm tra mỗi giây.
# NET_CHECK_INTERVAL_MS=5000

# Tùy chọn: Webhook Discord để nhắc vi phạm.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Bot Discord Voice (TTS trong kênh thoại) ---
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_VOICE_CHANNEL_ID=id-kênh-thoại
# BOT_HTTP_PORT=3001
# BOT_SECRET=secret-để-server-gọi-bot
# DISCORD_VOICE_BOT_URL=http://localhost:3001
# DISCORD_VOICE_BOT_SECRET= cùng giá trị với BOT_SECRET
