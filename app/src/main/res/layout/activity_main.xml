<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TOURNAMENT MONITOR"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="25dp"
        android:textColor="#00ff88"/>

    <EditText
        android:id="@+id/edtDeviceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên hiển thị (vd: Máy 01)"
        android:inputType="text"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/edtIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="192.168.1."
        android:inputType="textUri"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/edtPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3000"
        android:inputType="number"
        android:layout_marginBottom="15dp"/>

    <Switch
        android:id="@+id/switchFtp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MỞ CỔNG NHẬN FILE (LAN FTP)"
        android:textColor="#fff"
        android:layout_marginBottom="20dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Connect to Server"
        android:backgroundTint="#00ff88"
        android:textColor="#000"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Trạng thái: Chờ kết nối"
        android:textColor="#888"/>
</LinearLayout>