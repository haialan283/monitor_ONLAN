<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/monitor_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_app"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/monitor_accent"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giám sát thiết bị giải đấu"
            android:textSize="12sp"
            android:textColor="@color/monitor_text_muted"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_tournament"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:textColor="@color/monitor_text_muted"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/sectionTournament"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/monitor_surface"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_tournament_code"
                android:textColor="@color/monitor_text"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edtTournamentCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_tournament_code"
                android:inputType="textCapCharacters"
                android:textColor="@color/monitor_text"
                android:textColorHint="@color/monitor_text_muted"
                android:background="@drawable/monitor_input_bg"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtTournamentHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tournament_code_hint_live"
                android:textSize="11sp"
                android:textColor="@color/monitor_text_muted"
                android:lineSpacingMultiplier="1.2" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_connection"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:textColor="@color/monitor_text_muted"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/monitor_surface"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/edtDeviceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_device_name"
                android:inputType="text"
                android:textColor="@color/monitor_text"
                android:textColorHint="@color/monitor_text_muted"
                android:background="@drawable/monitor_input_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/edtIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_server_host"
                android:text="192.168.1."
                android:inputType="textUri"
                android:textColor="@color/monitor_text"
                android:textColorHint="@color/monitor_text_muted"
                android:background="@drawable/monitor_input_bg"
                android:padding="12dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/edtPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/label_port"
                android:text="3000"
                android:inputType="number"
                android:textColor="@color/monitor_text"
                android:textColorHint="@color/monitor_text_muted"
                android:background="@drawable/monitor_input_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <Switch
                android:id="@+id/switchFtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/switch_ftp"
                android:textColor="@color/monitor_text" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_connect"
            android:backgroundTint="@color/monitor_accent"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_idle"
            android:textColor="@color/monitor_text_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
