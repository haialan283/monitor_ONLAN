<!DOCTYPE html>

<html lang="vi">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>ÄÄƒng nháº­p â€” ArenaPulse</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>

        :root {

            --bg: #0b0d12;

            --surface: #12151c;

            --border: #252b38;

            --text: #e8ecf4;

            --text-muted: #8b93a7;

            --accent: #3d8bfd;

            --warn: #ef4444;

        }

        * { box-sizing: border-box; margin: 0; }

        body {

            min-height: 100vh;

            background: var(--bg);

            background-image: radial-gradient(ellipse 70% 50% at 50% -10%, rgba(61, 139, 253, 0.1), transparent);

            color: var(--text);

            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

            display: flex; align-items: center; justify-content: center;

            padding: 24px;

        }

        .box {

            background: var(--surface);

            border: 1px solid var(--border);

            border-radius: 12px;

            padding: 2rem 2rem 1.75rem;

            width: 100%; max-width: 380px;

            box-shadow: 0 8px 32px rgba(0,0,0,0.35);

        }

        .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 1.25rem; }

        .brand-icon {

            width: 40px; height: 40px; border-radius: 10px;

            background: linear-gradient(135deg, var(--accent), #6366f1);

            display: flex; align-items: center; justify-content: center;

            font-weight: 700; color: #fff; font-size: 18px;

        }

        h1 { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; }

        .subtitle { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem; line-height: 1.45; }

        .setup-msg { margin: 0 0 1rem; color: var(--text-muted); font-size: 0.85rem; display: none; line-height: 1.45; }

        .setup-msg code { font-size: 0.8rem; background: #181c26; padding: 2px 6px; border-radius: 4px; }

        label { display: block; font-size: 0.8rem; font-weight: 500; color: var(--text-muted); margin-bottom: 6px; }

        input {

            width: 100%; padding: 11px 12px;

            background: #181c26; border: 1px solid var(--border);

            color: var(--text); border-radius: 8px;

            margin-bottom: 1rem; font-size: 0.95rem;

            transition: border-color 0.15s, box-shadow 0.15s;

        }

        input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(61,139,253,0.15); }

        button {

            width: 100%; padding: 11px;

            background: linear-gradient(180deg, var(--accent), #2563eb);

            color: #fff; border: none; font-weight: 600;

            cursor: pointer; border-radius: 8px; font-size: 0.95rem;

            font-family: inherit;

            box-shadow: 0 2px 8px rgba(61,139,253,0.3);

        }

        button:hover { filter: brightness(1.05); }

        .err { color: var(--warn); font-size: 0.85rem; margin-top: 0.75rem; min-height: 1.2em; }

    </style>

</head>

<body>

    <div class="box">

        <div class="brand">

            <div class="brand-icon">AP</div>

            <h1>ArenaPulse</h1>

        </div>

        <p id="setup-msg" class="setup-msg">Server chÆ°a cáº¥u hĂ¬nh tĂ i khoáº£n. Äáº·t <code>DASHBOARD_ADMIN_USER</code> vĂ  <code>DASHBOARD_ADMIN_PASSWORD</code> trĂªn server rá»“i táº£i láº¡i trang.</p>

        <p class="subtitle">Nháº­p tĂ i khoáº£n vĂ  máº­t kháº©u Ä‘á»ƒ truy cáº­p Dashboard.</p>

        <form id="f" method="post" action="/api/auth/login">

            <label for="username">TĂ i khoáº£n</label>

            <input type="text" name="username" id="username" placeholder="admin" autocomplete="username" autofocus>

            <label for="password">Máº­t kháº©u</label>

            <input type="password" name="password" id="password" placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" autocomplete="current-password">

            <button type="submit">ÄÄƒng nháº­p</button>

        </form>

        <div class="err" id="err"></div>

    </div>

    <script>

        if (new URLSearchParams(window.location.search).get('setup') === '1') {

            document.getElementById('setup-msg').style.display = 'block';

        }

        document.getElementById('f').addEventListener('submit', async (e) => {

            e.preventDefault();

            const username = document.getElementById('username').value.trim();

            const password = document.getElementById('password').value;

            const err = document.getElementById('err');

            err.textContent = '';

            const res = await fetch('/api/auth/login', {

                method: 'POST',

                headers: { 'Content-Type': 'application/json' },

                body: JSON.stringify({ username, password })

            });

            const data = await res.json().catch(() => ({}));

            if (res.ok && data.ok) {

                window.location.href = data.role === 'admin' ? '/admin.html' : '/';

                return;

            }

            if (res.status === 503) {

                err.textContent = data.error || 'ChÆ°a cáº¥u hĂ¬nh tĂ i khoáº£n trĂªn server.';

                return;

            }

            err.textContent = data.error || 'ÄÄƒng nháº­p tháº¥t báº¡i.';

        });

    </script>

</body>

</html>

