<!DOCTYPE html>

<html lang="vi">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Cáº¥u hĂ¬nh giáº£i â€” ArenaPulse</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>

        :root {

            --bg: #0b0d12;

            --surface: #12151c;

            --surface-2: #181c26;

            --border: #252b38;

            --border-focus: #3d8bfd;

            --text: #e8ecf4;

            --text-muted: #8b93a7;

            --text-dim: #5c6478;

            --accent: #3d8bfd;

            --accent-soft: rgba(61, 139, 253, 0.12);

            --success: #22c55e;

            --success-soft: rgba(34, 197, 94, 0.12);

            --danger: #ef4444;

            --danger-soft: rgba(239, 68, 68, 0.12);

            --radius: 10px;

            --shadow: 0 4px 24px rgba(0, 0, 0, 0.35);

            --sidebar-w: 240px;

        }

        * { box-sizing: border-box; margin: 0; }

        html { scroll-behavior: smooth; }

        body {

            min-height: 100vh;

            background: var(--bg);

            background-image:

                radial-gradient(ellipse 80% 50% at 50% -20%, rgba(61, 139, 253, 0.08), transparent),

                linear-gradient(180deg, var(--bg) 0%, #090a0f 100%);

            color: var(--text);

            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

            font-size: 14px;

            line-height: 1.5;

        }



        .app-shell { display: flex; min-height: 100vh; }



        .sidebar {

            width: var(--sidebar-w);

            flex-shrink: 0;

            background: var(--surface);

            border-right: 1px solid var(--border);

            display: flex;

            flex-direction: column;

            position: sticky;

            top: 0;

            height: 100vh;

        }

        .sidebar-brand {

            padding: 20px 18px 16px;

            border-bottom: 1px solid var(--border);

        }

        .sidebar-brand .logo {

            display: flex;

            align-items: center;

            gap: 10px;

        }

        .sidebar-brand .logo-icon {

            width: 36px; height: 36px;

            border-radius: 8px;

            background: linear-gradient(135deg, var(--accent), #6366f1);

            display: flex; align-items: center; justify-content: center;

            font-size: 18px; font-weight: 700; color: #fff;

            box-shadow: 0 4px 12px rgba(61, 139, 253, 0.35);

        }

        .sidebar-brand h1 { font-size: 15px; font-weight: 700; letter-spacing: -0.02em; }

        .sidebar-brand p { font-size: 11px; color: var(--text-muted); margin-top: 2px; }



        .sidebar-nav { padding: 12px 10px; flex: 1; }

        .nav-label {

            font-size: 10px; font-weight: 600; letter-spacing: 0.08em;

            text-transform: uppercase; color: var(--text-dim);

            padding: 8px 10px 6px;

        }

        .nav-link {

            display: flex; align-items: center; gap: 10px;

            padding: 10px 12px; margin-bottom: 2px;

            border-radius: 8px; color: var(--text-muted);

            text-decoration: none; font-size: 13px; font-weight: 500;

            transition: background 0.15s, color 0.15s;

        }

        .nav-link:hover { background: var(--accent-soft); color: var(--text); }

        .nav-link .icon { width: 18px; text-align: center; opacity: 0.7; font-size: 14px; }



        .sidebar-footer {

            padding: 14px 12px;

            border-top: 1px solid var(--border);

            display: flex; flex-direction: column; gap: 8px;

        }

        .btn-ghost, .btn-outline {

            display: inline-flex; align-items: center; justify-content: center; gap: 6px;

            padding: 9px 14px; border-radius: 8px;

            font-size: 13px; font-weight: 500; cursor: pointer;

            text-decoration: none; transition: all 0.15s;

            font-family: inherit;

        }

        .btn-outline {

            background: transparent; border: 1px solid var(--border);

            color: var(--text-muted);

        }

        .btn-outline:hover { border-color: var(--text-muted); color: var(--text); background: var(--surface-2); }

        .btn-ghost {

            background: transparent; border: none; color: var(--text-dim);

        }

        .btn-ghost:hover { color: var(--danger); background: var(--danger-soft); }



        .main-wrap { flex: 1; min-width: 0; display: flex; flex-direction: column; }



        .topbar {

            padding: 16px 28px;

            border-bottom: 1px solid var(--border);

            background: rgba(18, 21, 28, 0.85);

            backdrop-filter: blur(8px);

            position: sticky; top: 0; z-index: 10;

        }

        .topbar h2 { font-size: 18px; font-weight: 600; letter-spacing: -0.02em; }

        .topbar p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }



        main { flex: 1; padding: 24px 28px 100px; max-width: 820px; }



        .card {

            background: var(--surface);

            border: 1px solid var(--border);

            border-radius: var(--radius);

            padding: 20px 22px;

            margin-bottom: 16px;

            box-shadow: var(--shadow);

        }

        .card-head {

            display: flex; align-items: flex-start; gap: 14px;

            margin-bottom: 16px;

        }

        .card-icon {

            width: 40px; height: 40px; flex-shrink: 0;

            border-radius: 10px;

            display: flex; align-items: center; justify-content: center;

            font-size: 18px;

        }

        .card-icon.tournament { background: var(--accent-soft); color: var(--accent); }

        .card-icon.whitelist { background: var(--success-soft); color: var(--success); }

        .card-icon.advanced { background: rgba(168, 85, 247, 0.12); color: #a855f7; }

        .card-icon.audit { background: rgba(245, 158, 11, 0.12); color: #f59e0b; }

        .audit-table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 8px; }

        table.audit-table { width: 100%; border-collapse: collapse; font-size: 12px; }

        table.audit-table th, table.audit-table td {

            padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--border);

        }

        table.audit-table th {

            background: var(--surface-2); color: var(--text-muted); font-weight: 600;

            font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em;

        }

        table.audit-table tr:last-child td { border-bottom: none; }

        table.audit-table td.mono { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-dim); }

        table.audit-table td.action { font-weight: 500; color: var(--accent); }

        .audit-empty { padding: 24px; text-align: center; color: var(--text-dim); font-size: 13px; }

        .audit-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; gap: 12px; }

        .btn-sm {

            padding: 6px 12px; font-size: 12px; border-radius: 6px;

            background: var(--surface-2); border: 1px solid var(--border);

            color: var(--text-muted); cursor: pointer; font-family: inherit;

        }

        .btn-sm:hover { border-color: var(--text-muted); color: var(--text); }

        .card-head h3 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }

        .card-head .hint { font-size: 12px; color: var(--text-muted); line-height: 1.45; }



        .field { margin-bottom: 14px; }

        .field:last-child { margin-bottom: 0; }

        label.field-label {

            display: block; font-size: 12px; font-weight: 500;

            color: var(--text-muted); margin-bottom: 6px;

        }

        label.field-label code {

            font-family: 'JetBrains Mono', monospace;

            font-size: 11px; color: var(--text-dim);

            background: var(--surface-2); padding: 1px 5px; border-radius: 4px;

        }

        input[type=text], input[type=number], textarea {

            width: 100%; padding: 10px 12px;

            background: var(--surface-2); border: 1px solid var(--border);

            color: var(--text); border-radius: 8px;

            font-size: 13px; font-family: 'JetBrains Mono', Consolas, monospace;

            transition: border-color 0.15s, box-shadow 0.15s;

        }

        input:focus, textarea:focus {

            outline: none;

            border-color: var(--border-focus);

            box-shadow: 0 0 0 3px rgba(61, 139, 253, 0.15);

        }

        input[type=text]#tournament-code { text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500; }

        textarea { min-height: 130px; resize: vertical; line-height: 1.55; }

        .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 14px; }

        @media (max-width: 640px) {

            .app-shell { flex-direction: column; }

            .sidebar { width: 100%; height: auto; position: relative; }

            .sidebar-nav { display: none; }

            main { padding: 16px 16px 90px; }

            .field-row { grid-template-columns: 1fr; }

        }



        .save-bar {

            position: fixed; bottom: 0; left: var(--sidebar-w); right: 0;

            padding: 14px 28px;

            background: rgba(18, 21, 28, 0.95);

            backdrop-filter: blur(10px);

            border-top: 1px solid var(--border);

            display: flex; align-items: center; gap: 14px; z-index: 20;

        }

        @media (max-width: 640px) { .save-bar { left: 0; padding: 12px 16px; } }



        .btn-primary {

            background: linear-gradient(180deg, var(--accent) 0%, #2563eb 100%);

            color: #fff; border: none;

            padding: 10px 22px; border-radius: 8px;

            font-size: 13px; font-weight: 600; cursor: pointer;

            font-family: inherit;

            box-shadow: 0 2px 8px rgba(61, 139, 253, 0.35);

            transition: transform 0.1s, box-shadow 0.15s, opacity 0.15s;

        }

        .btn-primary:hover:not(:disabled) { box-shadow: 0 4px 16px rgba(61, 139, 253, 0.45); transform: translateY(-1px); }

        .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }



        .status { font-size: 13px; color: var(--text-muted); }

        .status.ok { color: var(--success); }

        .status.err { color: var(--danger); }



        .overlay {

            display: none; position: fixed; inset: 0;

            background: rgba(11, 13, 18, 0.92);

            backdrop-filter: blur(6px);

            align-items: center; justify-content: center; z-index: 99;

        }

        .overlay.show { display: flex; }

        .overlay-box { text-align: center; color: var(--text-muted); }

        .spinner {

            width: 36px; height: 36px; margin: 0 auto 14px;

            border: 3px solid var(--border);

            border-top-color: var(--accent);

            border-radius: 50%;

            animation: spin 0.7s linear infinite;

        }

        @keyframes spin { to { transform: rotate(360deg); } }

    </style>

</head>

<body>

<div id="gate" class="overlay show">

    <div class="overlay-box">

        <div class="spinner"></div>

        <div>Äang kiá»ƒm tra quyá»n adminâ€¦</div>

    </div>

</div>



<div class="app-shell">

    <aside class="sidebar">

        <div class="sidebar-brand">

            <div class="logo">

                <div class="logo-icon">AP</div>

                <div>

                    <h1>ArenaPulse</h1>

                    <p>Báº£ng Ä‘iá»u khiá»ƒn giáº£i</p>

                </div>

            </div>

        </div>

        <nav class="sidebar-nav">

            <div class="nav-label">Cáº¥u hĂ¬nh</div>

            <a class="nav-link" href="#sec-tournament"><span class="icon">đŸ†</span> MĂ£ giáº£i</a>

            <a class="nav-link" href="#sec-whitelist"><span class="icon">âœ“</span> Whitelist app</a>

            <a class="nav-link" href="#sec-advanced"><span class="icon">â™</span> NĂ¢ng cao</a>

            <a class="nav-link" href="#sec-audit"><span class="icon">đŸ“‹</span> Nháº­t kĂ½</a>

        </nav>

        <div class="sidebar-footer">

            <a href="/" class="btn-outline">â† Quay láº¡i Dashboard</a>

            <button type="button" id="btn-logout" class="btn-ghost" onclick="logout()">ÄÄƒng xuáº¥t</button>

        </div>

    </aside>



    <div class="main-wrap">

        <header class="topbar">

            <h2>Cáº¥u hĂ¬nh giáº£i Ä‘áº¥u</h2>

            <p>Quáº£n lĂ½ mĂ£ giáº£i, whitelist á»©ng dá»¥ng vĂ  thĂ´ng sá»‘ heartbeat â€” Ă¡p dá»¥ng ngay khĂ´ng cáº§n restart.</p>

        </header>



        <main>

            <section id="sec-tournament" class="card">

                <div class="card-head">

                    <div class="card-icon tournament">đŸ†</div>

                    <div>

                        <h3>MĂ£ giáº£i</h3>

                        <p class="hint">Thiáº¿t bá»‹ app pháº£i nháº­p Ä‘Ăºng mĂ£ khi káº¿t ná»‘i LIVE. Äá»ƒ trá»‘ng = táº¯t báº¯t buá»™c mĂ£ giáº£i.</p>

                    </div>

                </div>

                <div class="field">

                    <label class="field-label" for="tournament-code">MĂ£ giáº£i</label>

                    <input type="text" id="tournament-code" placeholder="VD: FFWS2026" maxlength="32" autocomplete="off" spellcheck="false">

                </div>

            </section>



            <section id="sec-whitelist" class="card">

                <div class="card-head">

                    <div class="card-icon whitelist">âœ“</div>

                    <div>

                        <h3>Whitelist app (foreground)</h3>

                        <p class="hint">Má»™t package Android má»—i dĂ²ng. App ngoĂ i danh sĂ¡ch Ä‘Æ°á»£c coi lĂ  vi pháº¡m.</p>

                    </div>

                </div>

                <div class="field">

                    <label class="field-label" for="whitelist-apps"><code>whitelistApps</code></label>

                    <textarea id="whitelist-apps" placeholder="com.dts.freefireth&#10;com.android.chrome"></textarea>

                </div>

            </section>



            <section id="sec-advanced" class="card">

                <div class="card-head">

                    <div class="card-icon advanced">â™</div>

                    <div>

                        <h3>Overlay, noise &amp; timing</h3>

                        <p class="hint">Overlay whitelist: app váº½ Ä‘Ă¨ há»£p lá»‡. Noise: bá» qua khi Ä‘á»c foreground.</p>

                    </div>

                </div>

                <div class="field">

                    <label class="field-label" for="overlay-whitelist"><code>overlayWhitelistApps</code></label>

                    <textarea id="overlay-whitelist" rows="3"></textarea>

                </div>

                <div class="field">

                    <label class="field-label" for="noise-packages"><code>noisePackages</code></label>

                    <textarea id="noise-packages" rows="4"></textarea>

                </div>

                <div class="field-row">

                    <div class="field">

                        <label class="field-label" for="heartbeat-ms"><code>heartbeatIntervalMs</code> (ms)</label>

                        <input type="number" id="heartbeat-ms" min="1000" max="30000" step="500">

                    </div>

                    <div class="field">

                        <label class="field-label" for="disconnect-ms"><code>disconnectMs</code> (trá»‘ng = env)</label>

                        <input type="number" id="disconnect-ms" min="3000" max="120000" step="1000" placeholder="12000">

                    </div>

                </div>

            </section>



            <section id="sec-audit" class="card">

                <div class="card-head">

                    <div class="card-icon audit">đŸ“‹</div>

                    <div>

                        <h3>Nháº­t kĂ½ thao tĂ¡c</h3>

                        <p class="hint">ÄÄƒng nháº­p, lÆ°u cáº¥u hĂ¬nh admin, xĂ³a log vi pháº¡m â€” tá»‘i Ä‘a 500 má»¥c gáº§n nháº¥t.</p>

                    </div>

                </div>

                <div class="audit-toolbar">

                    <span class="hint" id="audit-count"></span>

                    <button type="button" class="btn-sm" onclick="loadAudit()">LĂ m má»›i</button>

                </div>

                <div class="audit-table-wrap" id="audit-wrap">

                    <div class="audit-empty" id="audit-empty">Äang táº£iâ€¦</div>

                    <table class="audit-table" id="audit-table" hidden>

                        <thead>

                            <tr>

                                <th>Thá»i gian</th>

                                <th>HĂ nh Ä‘á»™ng</th>

                                <th>Chi tiáº¿t</th>

                            </tr>

                        </thead>

                        <tbody id="audit-body"></tbody>

                    </table>

                </div>

            </section>

        </main>



        <div class="save-bar">

            <button type="button" class="btn-primary" id="btn-save" onclick="saveSettings()">LÆ°u cáº¥u hĂ¬nh</button>

            <span class="status" id="save-status"></span>

        </div>

    </div>

</div>



<script>

    function linesToArr(text) {

        return (text || '').split(/\r?\n/).map((s) => s.trim()).filter(Boolean);

    }

    function arrToLines(arr) {

        return Array.isArray(arr) ? arr.join('\n') : '';

    }



    async function ensureAdmin() {

        const gate = document.getElementById('gate');

        try {

            const res = await fetch('/api/auth/me', { cache: 'no-store' });

            if (res.status === 401) {

                window.location.href = '/login.html';

                return false;

            }

            const data = await res.json().catch(() => ({}));

            if (!data || data.role !== 'admin') {

                window.location.href = '/';

                return false;

            }

            gate.classList.remove('show');

            return true;

        } catch (_) {

            window.location.href = '/login.html';

            return false;

        }

    }



    async function loadSettings() {

        const res = await fetch('/api/admin/settings', { cache: 'no-store' });

        if (res.status === 401) { window.location.href = '/login.html'; return; }

        if (res.status === 403) { window.location.href = '/'; return; }

        if (!res.ok) throw new Error('KhĂ´ng táº£i Ä‘Æ°á»£c cáº¥u hĂ¬nh');

        const data = await res.json();

        document.getElementById('tournament-code').value = data.tournamentCode || '';

        const t = data.tournament || {};

        document.getElementById('whitelist-apps').value = arrToLines(t.whitelistApps);

        document.getElementById('overlay-whitelist').value = arrToLines(t.overlayWhitelistApps);

        document.getElementById('noise-packages').value = arrToLines(t.noisePackages);

        document.getElementById('heartbeat-ms').value = t.heartbeatIntervalMs || 2000;

        document.getElementById('disconnect-ms').value = t.disconnectMs != null ? t.disconnectMs : '';

    }



    async function saveSettings() {

        const btn = document.getElementById('btn-save');

        const status = document.getElementById('save-status');

        btn.disabled = true;

        status.textContent = 'Äang lÆ°uâ€¦';

        status.className = 'status';

        const disconnectRaw = document.getElementById('disconnect-ms').value.trim();

        const payload = {

            tournamentCode: document.getElementById('tournament-code').value.trim().toUpperCase(),

            whitelistApps: linesToArr(document.getElementById('whitelist-apps').value),

            overlayWhitelistApps: linesToArr(document.getElementById('overlay-whitelist').value),

            noisePackages: linesToArr(document.getElementById('noise-packages').value),

            heartbeatIntervalMs: parseInt(document.getElementById('heartbeat-ms').value, 10) || 2000,

            disconnectMs: disconnectRaw === '' ? null : parseInt(disconnectRaw, 10),

        };

        try {

            const res = await fetch('/api/admin/settings', {

                method: 'PUT',

                headers: { 'Content-Type': 'application/json' },

                body: JSON.stringify(payload),

            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok) throw new Error(data.error || res.status);

            status.textContent = 'ÄĂ£ lÆ°u â€” Ă¡p dá»¥ng ngay (whitelist + mĂ£ giáº£i).';

            status.className = 'status ok';

        } catch (e) {

            status.textContent = 'Lá»—i: ' + (e.message || e);

            status.className = 'status err';

        } finally {

            btn.disabled = false;

        }

    }



    const AUDIT_LABELS = {

        login: 'ÄÄƒng nháº­p',

        admin_settings: 'LÆ°u cáº¥u hĂ¬nh',

        session_import: 'Import phiĂªn',

        clear_logs: 'XĂ³a log vi pháº¡m',

    };



    function formatAuditTime(iso) {

        if (!iso) return 'â€”';

        try {

            const d = new Date(iso);

            return d.toLocaleString('vi-VN', { hour12: false });

        } catch (_) {

            return iso;

        }

    }



    async function loadAudit() {

        const empty = document.getElementById('audit-empty');

        const table = document.getElementById('audit-table');

        const body = document.getElementById('audit-body');

        const countEl = document.getElementById('audit-count');

        empty.hidden = false;

        empty.textContent = 'Äang táº£iâ€¦';

        table.hidden = true;

        try {

            const res = await fetch('/api/admin/audit?limit=50', { cache: 'no-store' });

            if (res.status === 401) { window.location.href = '/login.html'; return; }

            if (res.status === 403) { window.location.href = '/'; return; }

            if (!res.ok) throw new Error('KhĂ´ng táº£i Ä‘Æ°á»£c nháº­t kĂ½');

            const data = await res.json();

            const entries = Array.isArray(data.entries) ? data.entries : [];

            countEl.textContent = entries.length ? `${entries.length} má»¥c gáº§n nháº¥t` : 'ChÆ°a cĂ³ má»¥c nĂ o';

            if (!entries.length) {

                empty.textContent = 'ChÆ°a cĂ³ thao tĂ¡c nĂ o Ä‘Æ°á»£c ghi.';

                empty.hidden = false;

                table.hidden = true;

                return;

            }

            body.innerHTML = entries.map((e) => {

                const label = AUDIT_LABELS[e.action] || e.action || 'â€”';

                const detail = (e.detail || '').replace(/</g, '&lt;');

                return `<tr>

                    <td class="mono">${formatAuditTime(e.at)}</td>

                    <td class="action">${label}</td>

                    <td>${detail || 'â€”'}</td>

                </tr>`;

            }).join('');

            empty.hidden = true;

            table.hidden = false;

        } catch (err) {

            empty.textContent = 'Lá»—i: ' + (err.message || err);

            empty.hidden = false;

            table.hidden = true;

        }

    }



    async function logout() {

        try { await fetch('/api/auth/logout', { method: 'POST' }); } catch (_) { /* ignore */ }

        window.location.href = '/login.html';

    }



    (async () => {

        if (await ensureAdmin()) {

            await loadSettings();

            await loadAudit();

        }

    })();

</script>

</body>

</html>

